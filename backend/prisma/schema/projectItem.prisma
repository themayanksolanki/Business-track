enum ProjectItemType {
  group
  task
  subtask
}

enum ProjectItemStatus {
  todo
  doing
  completed
}

model ProjectItem {
  id             Int               @id @default(autoincrement())
  sequenceId     Int?
  // Denormalized from Project.organizationId at creation time — ProjectItem
  // has no direct org relation otherwise, but the per-org sequenceId counter
  // needs it without an extra join back through Project.
  organizationId Int?
  projectId      Int
  parentId       Int?
  type           ProjectItemType
  title          String
  description    String            @default("")
  status         ProjectItemStatus @default(todo)
  priority       ProjectPriority   @default(medium)
  assignedToId   Int?
  createdById    Int
  updatedById    Int?
  depth          Int
  order          Int               @default(0)
  startDate      DateTime?
  endDate        DateTime?
  attachmentCount Int              @default(0)
  // Snapshot of {userId, username} for whoever is currently @mentioned in the
  // description — never rendered (description has no separate read-only
  // view), used purely so updateItem can diff old vs new and only notify
  // newly-added mentions. Same "small, never independently queried list"
  // pattern as Project.links/detailsLayout.
  mentions       Json              @default("[]")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       ProjectItem?  @relation("ProjectItemHierarchy", fields: [parentId], references: [id])
  children     ProjectItem[] @relation("ProjectItemHierarchy")
  organization Organization? @relation(fields: [organizationId], references: [id])

  assignedTo User? @relation("ProjectItemAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User  @relation("ProjectItemCreatedBy", fields: [createdById], references: [id])
  updatedBy  User? @relation("ProjectItemUpdatedBy", fields: [updatedById], references: [id])

  tags          Tag[]
  comments      Comment[]
  attachments   Attachment[]
  notifications Notification[]

  @@index([projectId, parentId, order])
  @@unique([organizationId, sequenceId])
  @@map("project_items")
}

model Comment {
  id            Int      @id @default(autoincrement())
  projectItemId Int
  authorId      Int
  body          String   @db.VarChar(2000)
  // Snapshot of {userId, username} for whoever is @mentioned in this comment,
  // frozen at post/edit time — the frozen username is what the read-only
  // highlight-rendering regex matches against `body`, so a later rename of
  // the mentioned user doesn't break the highlight. Same JSON-list pattern
  // as Project.links.
  mentions      Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectItem ProjectItem @relation(fields: [projectItemId], references: [id], onDelete: Cascade)
  author      User        @relation("CommentAuthor", fields: [authorId], references: [id])

  notifications Notification[]

  @@index([projectItemId])
  @@map("comments")
}
