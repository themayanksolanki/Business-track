model ProjectRole {
  id             Int      @id @default(autoincrement())
  sequenceId     Int?
  title          String
  description    String   @default("")
  rank           Int      @default(0)
  isDefault      Boolean  @default(false)
  // Whether a member holding this role can edit (vs. only view) the
  // projects they're on — see canEditProject in projectController.js.
  // Defaults true so existing/custom roles aren't silently downgraded;
  // only the seeded "Viewer" default role is created with this false.
  canEdit        Boolean  @default(true)
  organizationId Int?
  createdById    Int
  updatedById    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  createdBy    User          @relation("ProjectRoleCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?         @relation("ProjectRoleUpdatedBy", fields: [updatedById], references: [id])

  members ProjectMember[]

  @@unique([organizationId, title])
  @@unique([organizationId, sequenceId])
  @@map("project_roles")
}
