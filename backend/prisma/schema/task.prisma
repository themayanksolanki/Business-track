enum TaskStatus {
  todo
  pending
  completed
}

model Task {
  id             Int        @id @default(autoincrement())
  sequenceId     Int?
  title          String
  description    String     @default("")
  status         TaskStatus @default(todo)
  startDate      DateTime?
  dueDate        DateTime?
  createdById    Int
  updatedById    Int?
  assignedToId   Int
  parentTaskId   Int?
  organizationId Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  // Denormalized so task list/detail responses don't need a join or a
  // per-render count query; kept in sync transactionally on upload/permanent
  // delete. Still counts attachments pending deletion — they only stop
  // counting once actually removed (see attachment.prisma pendingDeleteAt).
  attachmentCount Int      @default(0)

  createdBy    User          @relation("TaskCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?         @relation("TaskUpdatedBy", fields: [updatedById], references: [id])
  assignedTo   User          @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  parentTask   Task?         @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subtasks     Task[]        @relation("TaskHierarchy")
  organization Organization? @relation(fields: [organizationId], references: [id])

  tags          Tag[]
  attachments   Attachment[]
  notifications Notification[]

  @@index([organizationId])
  @@unique([organizationId, sequenceId])
  @@map("tasks")
}
